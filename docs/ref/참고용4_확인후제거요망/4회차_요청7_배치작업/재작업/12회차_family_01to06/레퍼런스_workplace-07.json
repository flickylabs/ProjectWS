  "witnessBudgets": {
    "workplace-07": {
      "tp-1": {
        "name": "박정훈 (품질총괄 디렉터)",
        "canState": [
          "태욱이 출하 지연과 여론 악화를 동시에 우려한 사실, 원본 채팅 보고 흐름을 안다.",
          "공식 회의와 보고 라인 범위에서 누가 어떤 방향으로 상황을 이해했는지는 알고 있다."
        ],
        "uncertain": [
          "세린이 멘토·동료 7명에게 편집 캡처를 돌린 정확한 전송 순서와 각 수신자 반응은 윤예진 접수기록을 직접 본 게 아니라서 모른다.",
          "e-3 메시지 ID와 현재 프로젝트 채널 헤더가 어떻게 분리되는지는 김도현 해시 비교표 없이는 확답 못 한다."
        ],
        "forbidden": [
          "익명 게시글 작성자가 세린이라고 단정해, 태욱이 회의에서 던진 '최근 결함 보고 올린 사람' 발언을 작성자 특정 증거처럼 말하는 것",
          "2년 전 결함등급 하향 회의록에서 C등급으로 돌린 문구나 후속 메일 전문을 직접 읽지 않은 범위까지 낭독하는 것",
          "디지털포렌식 레이어 분석 메모의 해상도 수치나 편집 PC 로그를 본인 기억인 것처럼 진술하는 것"
        ]
      },
      "tp-2": {
        "name": "윤예진 (윤리경영 조사담당)",
        "canState": [
          "게시글 보존본, 핫라인 접수 순서, 태욱의 초기 의심 발언, 세린의 보복 우려 진술을 함께 확인할 수 있다.",
          "평가·조사 기록의 버전 차이와 입력 순서는 시스템 범위 안에서 확인할 수 있다."
        ],
        "uncertain": [
          "태욱이 2년 전 회의에서 '외부 공포를 키우지 말자'고 한 맥락이 품질 관리였는지 은폐였는지는 당시 회의 참석자 진술 없이는 단정 못 한다.",
          "세린 단말 안에서 e-2 헤더 합성이 어떤 프로그램·레이어로 이뤄졌는지는 김도현 포렌식 분석 범위다."
        ],
        "forbidden": [
          "세린이 멘토·동료 7명에게 보낸 모든 캡처 파일 원본을 조사실 밖에서 그대로 공개하는 것",
          "태욱 평가란의 '협업 부적합' 문구를 인사 맥락 전체 없이 징계 확정처럼 단정하는 것",
          "핫라인 접수 전 본부 게시판 댓글 작성자들 실명이나 사적 반응을 수사 내용처럼 줄줄이 언급하는 것"
        ]
      },
      "tp-3": {
        "name": "김도현 (디지털포렌식 담당)",
        "canState": [
          "스크린샷 해시, 편집 레이어, 작업PC 로그, 과거 채팅 아카이브 재사용 여부를 원본 대조로 확인할 수 있다.",
          "원본 로그와 메타데이터를 대조해 어느 기록이 먼저였는지 확인할 수 있다."
        ],
        "uncertain": [
          "태욱이 왜 2년 전 채팅 문장을 이번 사건 삭제 지시처럼 받아들이길 원했는지, 혹은 세린이 어느 순간 편집을 정당화했는지는 로그만으로 단정하지 않는다.",
          "윤리경영 조사 접수기록에서 태욱의 '작성자가 누군지 감이 온다' 발언이 실제 인사 불이익 판단에 얼마나 직접 작용했는지는 윤예진 영역이다."
        ],
        "forbidden": [
          "윤예진이 확보한 보복 우려 진술서 전문이나 게시판 댓글 캡처를 포렌식 증거인 것처럼 대신 읽어 주는 것",
          "2년 전 결함등급 하향 회의록에서 누가 어떤 감정으로 침묵했는지 심리 해석까지 붙여 말하는 것",
          "편집 PC 로그에 남은 개인 폴더명·사적 파일명 등 조사 목적과 무관한 단말 세부를 공개하는 것"
        ]
      }
