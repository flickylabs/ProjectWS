{
  "caseId": "partnership-03",
  "executableTells": {
    "a": [
      {
        "id": "partnership-03:a:tell:flow_optimization",
        "appliesWhen": [
          "lying",
          "defensive",
          "avoiding"
        ],
        "lexicalHooks": [
          "흐름상",
          "투자자 관점에서",
          "운영 판단"
        ],
        "sentenceShape": "number_first",
        "cadence": "max_once_per_turn",
        "originalPattern": "약속을 어겼는지 묻는 질문에도 '흐름상 그게 맞았다'며 의도보다 효율을 먼저 말한다."
      },
      {
        "id": "partnership-03:a:tell:timeline_rebuild",
        "appliesWhen": [
          "cornered",
          "defensive",
          "shame"
        ],
        "lexicalHooks": [
          "0시 47분",
          "그 다음",
          "리허설 순서대로"
        ],
        "sentenceShape": "enumeration",
        "cadence": "once_every_2_turns",
        "originalPattern": "상대 비난을 듣자마자 새벽 메일, 캘린더 수정, 리허설 순서대로 시간표를 다시 짜서 답하려 한다."
      },
      {
        "id": "partnership-03:a:tell:emotion_deflection",
        "appliesWhen": [
          "avoiding",
          "hurt",
          "cornered"
        ],
        "lexicalHooks": [
          "감정 문제가 아니라",
          "성과 문제",
          "발표권이 아니라"
        ],
        "sentenceShape": "self_reference",
        "cadence": "on_trigger_only",
        "originalPattern": "상대가 배신감을 말하면 '발표권 감정이 아니라 투자 성과 문제'라고 정서 쟁점을 낮춘다."
      }
    ],
    "b": [
      {
        "id": "partnership-03:b:tell:headline_conclusion",
        "appliesWhen": [
          "lying",
          "defensive",
          "hurt"
        ],
        "lexicalHooks": [
          "결국",
          "요지는",
          "내 오프닝"
        ],
        "sentenceShape": "self_reference",
        "cadence": "max_once_per_turn",
        "originalPattern": "세부 경위를 건너뛰고 '결국 내 오프닝을 뺏은 거잖아' 같은 결론 문장부터 던진다."
      },
      {
        "id": "partnership-03:b:tell:pressure_echo",
        "appliesWhen": [
          "cornered",
