  "beatScripts": [
    {
      "id": "partnership-10:beat:a:d-1:deny",
      "caseId": "partnership-10",
      "party": "a",
      "disputeId": "d-1",
      "beatType": "deny",
      "line": "빈 반 시간이 먼저 보였지, 최종 채용 확정부터 누른 건 아닙니다. 저는 그걸 체험근무 세팅으로 봤어요.",
      "behaviorHint": "근무표를 손끝으로 짚으며 숫자를 세듯 말하고 눈을 바로 마주치지 않는다.",
      "applicableStates": [
        "S0"
      ],
      "afterEvidence": null
    },
    {
      "id": "partnership-10:beat:a:d-1:hedge",
      "caseId": "partnership-10",
      "party": "a",
      "disputeId": "d-1",
      "beatType": "hedge",
      "line": "혜린 씨가 '이번 주부터 한번 같이 돌아보자'고 했습니다. 저는 그 말을 시작 신호로 읽은 겁니다.",
      "behaviorHint": "짧게 숨을 삼키고 따옴표를 치듯 손가락을 접는다.",
      "applicableStates": [
        "S1"
      ],
      "afterEvidence": null
    },
    {
