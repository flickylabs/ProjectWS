    {
      "id": "partnership-06:beat:a:d-1:partial",
      "caseId": "partnership-06",
      "party": "a",
      "disputeId": "d-1",
      "beatType": "partial",
      "line": "대체 모델 얘기를 꺼낸 건 맞아요. 그때 매장을 본 사람은 저였고, 그 정도 판단은 필요하다고 봤습니다.",
      "behaviorHint": "손으로 테이블을 한번 짚고 말한다.",
      "applicableStates": [
        "S2"
      ],
      "afterEvidence": null
