                "blockVector": "authenticity",
                "revealAtom": "spouse10:a:d-2:unlock:s2:0",
                "lieAdvance": true
              }
            },
            {
              "id": "dossier-1.a.q2",
              "text": "평소 습관상 '본가'라고 썼다는 이유로, 배우자에게 직접 확인을 생략하신 겁니까?",
