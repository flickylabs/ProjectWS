            },
            {
              "id": "dossier-2.b.q2",
              "text": "귀의 피와 앞발 패드 상처 중 어느 쪽이 직접 원인 판단에 더 중요했습니까?",
              "attackVector": "context",
              "onSuccess": {
                "blockVector": "context",
                "revealAtom": "neighbor03:b:d-4:unlock:s3:0",
                "lieAdvance": true
